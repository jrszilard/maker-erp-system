# Caddyfile template — COPY THIS TO `Caddyfile` AND EDIT, then deploy.
#
#   cp Caddyfile.example Caddyfile
#
# `Caddyfile` is gitignored: it holds your basic-auth credentials.
#
# WHY THE HASH LIVES HERE AND NOT IN .env:
#   A bcrypt hash looks like `$2a$14$....`. docker-compose interpolates `$` sequences
#   in .env values ($2a, $14, ...) and corrupts the hash — Caddy then either fails to
#   parse it (crash-loop) or rejects every login (401). Pasting the hash literally here
#   keeps it out of every interpolation layer. (The same bug bit the smoke test; it was
#   fixed the same way — bake the literal hash into the Caddyfile.)
#
# Only the domain comes from .env (no `$` in a hostname, so interpolation is safe).
#
# Caddy v2.8+: the directive is `basic_auth` (older 2.x: `basicauth`).

{$MAKER_DOMAIN} {
	# Everything is behind basic-auth EXCEPT /health, which is intentionally left PUBLIC
	# so an external uptime monitor (UptimeRobot / Healthchecks / etc.) can verify the app
	# is actually serving — not merely that Caddy is up. Monitoring /health *through* auth
	# is theater: an unauthenticated probe gets a 401 that Caddy returns itself, without
	# ever touching the app, so the app could be dead and the check still "passes".
	# /health returns no sensitive data. See docs/monitoring.md.
	@protected not path /health /health/* /api/v1/integration/*
	basic_auth @protected {
		# Replace BOTH the username and the hash below.
		# Generate the hash (note the literal password in single quotes):
		#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
		# Paste the FULL hash verbatim. Caddy will refuse to start until this is a real
		# bcrypt hash — that is intentional (fail loud, never silently insecure).
		your-username REPLACE_WITH_CADDY_HASH
	}
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
	request_body {
		max_size 25MB
	}
	reverse_proxy app:8000
}
