# Copy to .env and fill in. NEVER commit the real .env.

# The commit SHA of jrszilard/theseus-erp to deploy (not a tag — tags are mutable).
# Use a SHA from main once PR #3 (Plan 5 upstream) is merged. Must be the FULL 40-char
# SHA — BuildKit's git-context fetch can fail on an abbreviated SHA.
THESEUS_REF=REPLACE_WITH_COMMIT_SHA

# Your domain (DNS A-record must point at this VPS).
MAKER_DOMAIN=maker.example.com

# NOTE: the basic-auth username + password hash are NOT set here. A bcrypt hash's `$`
# chars are corrupted by compose .env interpolation, so they live in the Caddyfile.
# Copy Caddyfile.example -> Caddyfile and paste the hash there. See Caddyfile.example.

# Postgres password. Generate:  openssl rand -hex 24
POSTGRES_PASSWORD=REPLACE_ME

# MinIO root credentials. Generate each:  openssl rand -hex 24
MINIO_ROOT_USER=REPLACE_ME
MINIO_ROOT_PASSWORD=REPLACE_ME

# App secret key. Generate:  openssl rand -hex 32
SECRET_KEY=REPLACE_ME

# Integration API token for an external storefront (Bearer). Empty = integration API disabled.
# Generate with: openssl rand -hex 32
INTEGRATION_API_TOKEN=
